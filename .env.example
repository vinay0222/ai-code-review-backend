# ─────────────────────────────────────────────────────────────────────────────
# AI Code Review — Backend Environment Variables
# Copy this file to .env and fill in the real values before starting the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info       # debug | info | warn | error

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# In production, set this to your Vercel URL (no trailing slash).
ALLOWED_ORIGINS=http://localhost:5173
# Example for production:
# ALLOWED_ORIGINS=https://ai-code-review.vercel.app,https://yourdomain.com

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:        http://localhost:5173  (or your Vercel URL in prod)
# Callback URL:        http://localhost:3001/auth/github/callback  (or your Render URL in prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# The URL GitHub will redirect to after OAuth (must match GitHub App settings exactly)
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback
# Production:
# GITHUB_CALLBACK_URL=https://your-backend.onrender.com/auth/github/callback

# Frontend URL used to redirect the browser back after OAuth
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://ai-code-review.vercel.app

# ── GitHub server-level fallback token (optional) ─────────────────────────────
# Used for unauthenticated callers (GitHub Actions) and as a fallback when the
# user has not yet connected their GitHub account.
# Create at: https://github.com/settings/tokens (classic) — scope: repo
GITHUB_TOKEN=

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Create a service account at:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key exactly as-is (including -----BEGIN/END----- lines).
# Wrap in double quotes and use \n for newlines.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
